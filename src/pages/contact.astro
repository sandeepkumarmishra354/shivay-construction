---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.jsx';
---

<Layout 
  title="Contact Us | Shivay Construction Company"
  description="Get in touch with Shivay Construction Company for joint ventures, subcontracting, and railway tender inquiries."
>
  <!-- Contact Hero -->
  <section class="contact-hero section">
    <div class="container text-center">
      <span class="hero-badge">Get in touch</span>
      <h1>Contact Our Tendering Desk</h1>
      <p style="margin: 1.5rem auto 0; max-width: 75ch;">
        Whether you are a government official with contract queries, an engineering firm looking for joint ventures, or a subcontractor, our communication channels are open.
      </p>
    </div>
  </section>

  <!-- Contact Form & Info Grid -->
  <section class="contact-grid-section section section-alt">
    <div class="container contact-grid">
      <!-- Left: Contact Form -->
      <div class="contact-form-container">
        <ContactForm client:load />
      </div>

      <!-- Right: Contact Cards -->
      <div class="contact-info-container">
        <div class="card contact-card">
          <div class="card-content">
            <div class="contact-icon-box">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="var(--accent)" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <div class="contact-card-text">
              <h3>Corporate Office Address</h3>
              <p>Shivay Tower, Plot No. 44, Sector 62, Noida, Uttar Pradesh, Pin - 201301</p>
            </div>
          </div>
        </div>

        <div class="card contact-card mt-4">
          <div class="card-content">
            <div class="contact-icon-box">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="var(--accent)" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </div>
            <div class="contact-card-text">
              <h3>Phone Channels</h3>
              <p><strong>Tender Bidding:</strong> +91-9876543210</p>
              <p><strong>Corporate HR:</strong> +91-9876543211</p>
            </div>
          </div>
        </div>

        <div class="card contact-card mt-4">
          <div class="card-content">
            <div class="contact-icon-box">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="var(--accent)" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
            </div>
            <div class="contact-card-text">
              <h3>Email Communications</h3>
              <p><strong>Tenders & JVs:</strong> tenders@shivayconstruction.co.in</p>
              <p><strong>General Info:</strong> info@shivayconstruction.co.in</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Location Map Visual -->
  <section class="map-section section">
    <div class="container">
      <div class="heading-accent-center mb-8">
        <h2>Our Corporate Headquarters Location</h2>
        <p class="text-center">Located in Noida's premier industrial and technology hub, ensuring fast connectivity to regional rail authority offices.</p>
      </div>
      <div class="map-container-mock card">
        <div class="card-content text-center">
          <div class="map-grid-graphic">
            <div class="map-road road-y"></div>
            <div class="map-road road-x"></div>
            <div class="map-marker-glow"></div>
            <span class="map-marker-label">SHIVAY TOWER, SECTOR 62</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    padding-top: calc(var(--header-height) + 3rem);
    background: radial-gradient(circle at bottom, rgba(249, 115, 22, 0.03) 0%, transparent 60%);
  }

  .contact-grid-section {
    border-top: 1px solid var(--border-dark);
    border-bottom: 1px solid var(--border-dark);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .contact-card {
    border: 1px solid var(--border-dark);
  }

  .contact-card .card-content {
    display: flex;
    gap: 1.25rem;
  }

  .contact-icon-box {
    width: 48px;
    height: 48px;
    background: rgba(249, 115, 22, 0.05);
    border: 1px solid rgba(249, 115, 22, 0.15);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-card-text h3 {
    font-size: 1.15rem;
    color: var(--text-light);
    margin-bottom: 0.35rem;
  }

  .contact-card-text p {
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* Map Mock Graphic CSS */
  .map-container-mock {
    height: 350px;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--border-dark);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .map-grid-graphic {
    width: 100%;
    height: 250px;
    border: 1px dashed rgba(255, 255, 255, 0.05);
    position: relative;
    background-color: #0b0f19;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  /* Mock road grids */
  .map-road {
    position: absolute;
    background: rgba(255, 255, 255, 0.03);
  }
  .road-y {
    width: 40px;
    height: 100%;
    left: 45%;
    border-left: 1px dashed rgba(255, 255, 255, 0.1);
    border-right: 1px dashed rgba(255, 255, 255, 0.1);
  }
  .road-x {
    height: 40px;
    width: 100%;
    top: 40%;
    border-top: 1px dashed rgba(255, 255, 255, 0.1);
    border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
  }

  .map-marker-glow {
    position: absolute;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: var(--accent);
    left: 47%;
    top: 43%;
    box-shadow: 0 0 20px 8px rgba(249, 115, 22, 0.6);
    animation: markerPulse 2s infinite;
  }

  @keyframes markerPulse {
    0% { transform: scale(0.9); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
    100% { transform: scale(0.9); opacity: 1; }
  }

  .map-marker-label {
    position: absolute;
    left: 47%;
    top: calc(43% + 28px);
    transform: translateX(-40%);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-light);
    background: rgba(15, 23, 42, 0.85);
    border: 1px solid var(--accent);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    letter-spacing: 0.5px;
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
