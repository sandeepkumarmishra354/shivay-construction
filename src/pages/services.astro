---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Our Services | Shivay Construction Company"
  description="Explore our specialized services including Overhead Electrification (OHE), broad gauge track linking, civil bridges, and railway signaling."
>
  <!-- Services Hero -->
  <section class="services-hero section">
    <div class="container text-center">
      <span class="hero-badge">Engineering Capabilities</span>
      <h1>Our Specialized Railway Services</h1>
      <p style="margin: 1.5rem auto 0; max-width: 75ch;">
        Shivay Construction Company offers a full suite of Engineering, Procurement, and Construction (EPC) services tailored specifically to government railway networks.
      </p>
    </div>
  </section>

  <!-- Service Detail 1: Electrification -->
  <section id="electrification" class="service-detail-section section section-alt">
    <div class="container grid-2">
      <div class="service-detail-text">
        <span class="service-number">01</span>
        <h2 class="heading-accent">Overhead Electrification (OHE) & Traction</h2>
        <p class="mb-4">
          To support high-speed electric locomotives, our electrical engineering team delivers complete 25 kV AC Overhead Equipment (OHE) installations from scratch.
        </p>
        <h4 class="tech-subheading">Technical Specialties Include:</h4>
        <ul class="specs-list">
          <li><strong>Mast & Portal Erection:</strong> Precise alignment and concrete foundation casting for steel OHE masts.</li>
          <li><strong>Wiring & Tensioning:</strong> Automated drawing and mechanical tensioning of copper contact and catenary wires.</li>
          <li><strong>Substations (PSI):</strong> Installation of Traction Substations (TSS), Feeding Posts (FP), and Sectioning Posts (SP/SSP) to regulate power supply.</li>
          <li><strong>Modification Works:</strong> Height modifications of existing OHE for double-stack containers and metro structures.</li>
        </ul>
      </div>
      <div class="service-detail-graphic">
        <div class="wiring-blueprint">
          <div class="catenary-wire"></div>
          <div class="dropper d-1"></div>
          <div class="dropper d-2"></div>
          <div class="dropper d-3"></div>
          <div class="contact-wire"></div>
          <div class="pantograph-touch"></div>
          <div class="blueprint-tag">25kV OHE WIRE SYSTEM</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Detail 2: Track Works -->
  <section id="track" class="service-detail-section section">
    <div class="container grid-2">
      <div class="service-detail-graphic order-mobile-2">
        <div class="track-cross-blueprint">
          <div class="rail-bar left"></div>
          <div class="rail-bar right"></div>
          <div class="concrete-sleeper-base"></div>
          <div class="ballast-fill"></div>
          <div class="blueprint-tag">CROSS-SECTION OF TRACK BED</div>
        </div>
      </div>
      <div class="service-detail-text order-mobile-1">
        <span class="service-number">02</span>
        <h2 class="heading-accent">Track Laying, Linking & Rehabilitation</h2>
        <p class="mb-4">
          From broad gauge line doubling to station yard loops, we offer complete track construction services utilizing automated sleeper assembly and ballast profiling.
        </p>
        <h4 class="tech-subheading">Technical Specialties Include:</h4>
        <ul class="specs-list">
          <li><strong>Track Doubling & Linking:</strong> Assembly of steel rails on pre-stressed concrete sleepers with elastic rail clips.</li>
          <li><strong>Welding & Joints:</strong> In-situ Alumino-Thermit welding (AT welding) and mobile Flash Butt welding of long rails.</li>
          <li><strong>Ballast Profile:</strong> Spreading and mechanical packing of high-quality track ballast for load absorption.</li>
          <li><strong>Yard Remodeling:</strong> Installation of complex rail crossovers, switches, and points in functional station yards.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Service Detail 3: Civil Bridges -->
  <section id="civil" class="service-detail-section section section-alt">
    <div class="container grid-2">
      <div class="service-detail-text">
        <span class="service-number">03</span>
        <h2 class="heading-accent">Civil Infrastructure & Bridge Works</h2>
        <p class="mb-4">
          We construct heavy-load foundations and bridge superstructures designed to withstand decades of intensive railway traffic.
        </p>
        <h4 class="tech-subheading">Technical Specialties Include:</h4>
        <ul class="specs-list">
          <li><strong>Major Concrete Bridges:</strong> Pile foundation, well foundation, and pre-stressed concrete (PSC) box girder construction.</li>
          <li><strong>ROBs & RUBs:</strong> Building Road Over Bridges (ROB) and Road Under Bridges (RUB) to eliminate dangerous level crossings.</li>
          <li><strong>Railway Formations:</strong> Soil compaction, blanketing, and drainage construction for railway banks.</li>
          <li><strong>Station Buildings:</strong> Design-build services for passenger terminals, control cabins, and platform structures.</li>
        </ul>
      </div>
      <div class="service-detail-graphic">
        <div class="bridge-arch-blueprint">
          <div class="bridge-span"></div>
          <div class="bridge-pier left"></div>
          <div class="bridge-pier right"></div>
          <div class="water-line"></div>
          <div class="blueprint-tag">BRIDGE FOUNDATION DETAIL</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Detail 4: Signaling -->
  <section id="telecom" class="service-detail-section section">
    <div class="container grid-2">
      <div class="service-detail-graphic order-mobile-2">
        <div class="signalling-blueprint">
          <div class="signal-pole"></div>
          <div class="signal-lamp amber"></div>
          <div class="signal-lamp green"></div>
          <div class="signal-lamp red"></div>
          <div class="blueprint-tag">AUTOMATIC BLOCK SIGNALING</div>
        </div>
      </div>
      <div class="service-detail-text order-mobile-1">
        <span class="service-number">04</span>
        <h2 class="heading-accent">Signalling & Telecommunication (S&T)</h2>
        <p class="mb-4">
          Modern trains require reliable automation systems. We execute safety-grade signaling tenders ensuring zero-error communication.
        </p>
        <h4 class="tech-subheading">Technical Specialties Include:</h4>
        <ul class="specs-list">
          <li><strong>Electronic Interlocking (EI):</strong> Setup of computer-based interlocking systems to control train movements.</li>
          <li><strong>Cable Layouts:</strong> Trenching, laying, and termination of underground optical fiber cables (OFC) and quad cables.</li>
          <li><strong>Track Circuits:</strong> Installation of digital axle counters and electrical track circuits for occupancy monitoring.</li>
          <li><strong>Signaling Cabins:</strong> Civil construction and electrical layout of station relay rooms and signal cabins.</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .services-hero {
    padding-top: calc(var(--header-height) + 3rem);
    background: radial-gradient(circle at bottom, rgba(249, 115, 22, 0.03) 0%, transparent 60%);
  }

  .service-detail-section {
    border-top: 1px solid var(--border-dark);
  }

  .service-number {
    font-family: var(--font-title);
    font-size: 3.5rem;
    font-weight: 800;
    color: rgba(249, 115, 22, 0.12);
    line-height: 1;
    display: block;
    margin-bottom: 0.5rem;
  }

  .tech-subheading {
    font-family: var(--font-title);
    color: var(--amber);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .specs-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .specs-list li {
    font-size: 0.95rem;
    position: relative;
    padding-left: 1.5rem;
  }

  .specs-list li::before {
    content: '▪';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 1.2rem;
    line-height: 1;
    top: 0;
  }

  /* Custom Blueprints CSS Graphics */
  .service-detail-graphic {
    background: rgba(30, 41, 59, 0.4);
    border: 1px solid var(--border-dark);
    height: 320px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .blueprint-tag {
    position: absolute;
    bottom: 1.5rem;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 0.7rem;
    font-family: var(--font-title);
    letter-spacing: 2.5px;
    color: var(--text-muted);
    font-weight: 600;
  }

  /* 1. OHE Graphic */
  .wiring-blueprint {
    width: 80%;
    height: 150px;
    position: relative;
    border-left: 3px solid var(--text-muted); /* Mast */
  }

  .catenary-wire {
    position: absolute;
    height: 2px;
    background: var(--text-muted);
    left: 0;
    right: 0;
    top: 30px;
    border-radius: 50% 50% 0 0; /* Creates curved effect */
    transform: scaleY(0.2);
  }

  .contact-wire {
    position: absolute;
    height: 2px;
    background: var(--accent);
    left: 0;
    right: 0;
    top: 80px;
  }

  .dropper {
    position: absolute;
    width: 1px;
    background: rgba(255, 255, 255, 0.2);
  }
  .d-1 { left: 25%; height: 40px; top: 40px; }
  .d-2 { left: 50%; height: 46px; top: 34px; }
  .d-3 { left: 75%; height: 40px; top: 40px; }

  /* 2. Track bed graphic */
  .track-cross-blueprint {
    width: 80%;
    height: 160px;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  .rail-bar {
    position: absolute;
    width: 10px;
    height: 35px;
    background: var(--text-light-muted);
    bottom: 50px;
  }
  .rail-bar.left { left: 28%; }
  .rail-bar.right { right: 28%; }

  .concrete-sleeper-base {
    width: 60%;
    height: 20px;
    background: #475569;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    margin-bottom: 30px;
  }

  .ballast-fill {
    width: 80%;
    height: 30px;
    background: repeating-linear-gradient(45deg, #1e293b, #1e293b 5px, #0f172a 5px, #0f172a 10px);
    border-top: 1px dashed var(--amber);
  }

  /* 3. Bridge Graphic */
  .bridge-arch-blueprint {
    width: 80%;
    height: 150px;
    position: relative;
  }

  .bridge-span {
    position: absolute;
    height: 15px;
    background: linear-gradient(180deg, var(--accent), var(--accent-hover));
    left: 5%;
    right: 5%;
    top: 50px;
    border-radius: 3px;
  }

  .bridge-pier {
    position: absolute;
    width: 25px;
    height: 70px;
    background: #334155;
    bottom: 0;
  }
  .bridge-pier.left { left: 20%; }
  .bridge-pier.right { right: 20%; }

  .water-line {
    position: absolute;
    left: 5%;
    right: 5%;
    height: 2px;
    border-bottom: 2px dashed var(--text-muted);
    bottom: 15px;
    opacity: 0.4;
  }

  /* 4. Signaling Graphic */
  .signalling-blueprint {
    width: 50px;
    height: 180px;
    position: relative;
    border-left: 4px solid #334155;
    margin-bottom: 20px;
  }

  .signal-pole {
    position: absolute;
    width: 24px;
    height: 70px;
    background: #0f172a;
    border: 2px solid var(--text-muted);
    border-radius: 12px;
    left: -14px;
    top: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    align-items: center;
    padding: 6px 0;
  }

  .signal-lamp {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #1e293b;
  }

  .signal-lamp.red { background: #ef4444; box-shadow: 0 0 10px rgba(239, 68, 68, 0.5); }

  @media (max-width: 768px) {
    .service-detail-section {
      grid-template-columns: 1fr;
    }
    .order-mobile-1 { order: 1; }
    .order-mobile-2 { order: 2; }
  }
</style>
