---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Shivay Construction Company | Railway Tenders & Infrastructure EPC"
  description="Premier Class-A railway contractor in India. Specializing in railway tenders, OHE electrification, track linking, bridges, and signaling solutions."
>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-background-grid"></div>
    <div class="container hero-content">
      <span class="hero-badge animate-fade-in">Class-A Railway EPC Contractor</span>
      <h1 class="animate-fade-in" style="animation-delay: 0.1s;">
        Engineering the Future of <br/>
        <span class="text-accent">Railway Infrastructure</span>
      </h1>
      <p class="animate-fade-in" style="animation-delay: 0.2s;">
        Shivay Construction Company executes complex government railway tenders with a focus on safety, speed, and engineering precision. Specializing in Overhead Electrification (OHE), track linking, and civil bridge works.
      </p>
      <div class="hero-ctas animate-fade-in" style="animation-delay: 0.3s;">
        <a href="/shivay-construction/projects" class="btn btn-primary">
          View Completed Tenders
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <a href="/shivay-construction/contact" class="btn btn-secondary">Joint Venture / Inquiry</a>
      </div>
    </div>
  </section>

  <!-- Metrics / Stats Section -->
  <section class="stats-section section-alt">
    <div class="container">
      <div class="grid-4">
        <div class="stat-card">
          <span class="stat-number">150+ <span class="stat-unit">KM</span></span>
          <span class="stat-label">Tracks Laid & Linked</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">450+ <span class="stat-unit">KM</span></span>
          <span class="stat-label">OHE Electrified</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">25+</span>
          <span class="stat-label">Major Railway Tenders Executed</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">0</span>
          <span class="stat-label">Lost Time Injury (Safety Record)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Services Showcase -->
  <section class="services-overview-section section">
    <div class="container">
      <div class="heading-accent-center mb-8">
        <h2>Our Core Core Specializations</h2>
        <p class="text-center">Delivering end-to-end engineering capabilities for Indian Railways infrastructure projects.</p>
      </div>

      <div class="grid-2">
        <div class="card service-overview-card">
          <div class="card-content">
            <div class="service-icon-box">
              <!-- Electrical Tower SVG -->
              <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="var(--accent)" stroke-width="2">
                <path d="M12 2L4 22M12 2l8 20M4 22h16M2 14h20M5 8h14M12 2v20" />
              </svg>
            </div>
            <h3>Railway Electrification (OHE/PSI)</h3>
            <p>Design, supply, erection, testing, and commissioning of 25kV OHE systems, traction substations, and switching stations to power modern high-speed trains.</p>
            <a href="/shivay-construction/services#electrification" class="learn-more-link">
              Read Technical Specs 
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          </div>
        </div>

        <div class="card service-overview-card">
          <div class="card-content">
            <div class="service-icon-box">
              <!-- Track / Bridge SVG -->
              <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="var(--accent)" stroke-width="2">
                <path d="M4 3v18M20 3v18M4 7h16M4 12h16M4 17h16" />
              </svg>
            </div>
            <h3>Track Laying & Upgradation</h3>
            <p>Complete track construction (broad gauge/standard gauge), ballast collection, flash-butt welding, sleepers laying, and modern track renewals.</p>
            <a href="/shivay-construction/services#track" class="learn-more-link">
              Read Technical Specs 
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          </div>
        </div>

        <div class="card service-overview-card">
          <div class="card-content">
            <div class="service-icon-box">
              <!-- Bridge / Civil SVG -->
              <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="var(--accent)" stroke-width="2">
                <path d="M3 12h18M6 12v6M18 12v6M10 12v6M14 12v6M3 6l9 6 9-6" />
              </svg>
            </div>
            <h3>Bridges & Civil Infrastructure</h3>
            <p>Design and structural construction of major and minor bridges, railway formations, earthworks, blanketing, and passenger station buildings.</p>
            <a href="/shivay-construction/services#civil" class="learn-more-link">
              Read Technical Specs 
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          </div>
        </div>

        <div class="card service-overview-card">
          <div class="card-content">
            <div class="service-icon-box">
              <!-- Signaling SVG -->
              <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="var(--accent)" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <circle cx="12" cy="8" r="2" fill="var(--accent)" />
                <circle cx="12" cy="16" r="2" />
              </svg>
            </div>
            <h3>Signalling & Telecommunication</h3>
            <p>Installation of modern Electronic Interlocking, signaling cabins, underground cable laying, and optical fiber communications networks for safe train control.</p>
            <a href="/shivay-construction/services#telecom" class="learn-more-link">
              Read Technical Specs 
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tender Bidding Competency -->
  <section class="competency-section section section-alt">
    <div class="container competency-grid">
      <div class="competency-text">
        <span class="text-accent font-semibold text-sm uppercase tracking-wider">Bidding Competency</span>
        <h2 class="heading-accent">Tendering Eligibility & Quality Control</h2>
        <p class="mb-4">
          As a registered Class-A contractor, Shivay Construction Company meets the stringent financial turnover and technical experience criteria required to participate in high-value Indian Railways e-tenders (IREPS).
        </p>
        <p class="mb-8">
          We maintain an extensive inventory of modern railway machinery (OHE wiring trains, track compactors, and heavy excavators) alongside an in-house quality testing laboratory ensuring compliance with RDSO specifications.
        </p>
        <div class="competency-list">
          <div class="competency-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="3" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Registered on IREPS and Government e-Marketplace (GeM)</span>
          </div>
          <div class="competency-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="3" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Rigorous safety compliance aligned with IR General Rules</span>
          </div>
          <div class="competency-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="3" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Proven record of executing projects within scheduled track-blocks</span>
          </div>
        </div>
      </div>
      <div class="competency-visual">
        <div class="visual-blueprint">
          <div class="blueprint-line track-horizontal-1"></div>
          <div class="blueprint-line track-horizontal-2"></div>
          <div class="blueprint-sleeper s-1"></div>
          <div class="blueprint-sleeper s-2"></div>
          <div class="blueprint-sleeper s-3"></div>
          <div class="blueprint-sleeper s-4"></div>
          <div class="blueprint-sleeper s-5"></div>
          <div class="blueprint-label">RAILWAY LAYOUT CONFIGURATION</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner section">
    <div class="container text-center">
      <h2>Collaborate on Upcoming Railway Tenders?</h2>
      <p style="margin: 1rem auto 2rem;">
        We partner with leading engineering firms for joint venture (JV) tenders and sub-contracting operations across North Central, South Eastern, and East Coast Railway zones.
      </p>
      <a href="/shivay-construction/contact" class="btn btn-primary btn-lg">Connect with Tendering Team</a>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section styles */
  .hero-section {
    position: relative;
    padding: calc(var(--header-height) + 4rem) 0 6rem;
    min-height: 85vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-background-grid {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* Create grid lines similar to draft blueprint */
    background-size: 40px 40px;
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    z-index: 1;
  }

  .hero-background-grid::after {
    content: '';
    position: absolute;
    bottom: -10%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(249, 115, 22, 0.08) 0%, transparent 70%);
    z-index: 2;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-badge {
    align-self: flex-start;
    background: rgba(249, 115, 22, 0.1);
    color: var(--accent);
    border: 1px solid rgba(249, 115, 22, 0.25);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 50px;
  }

  .hero-content p {
    font-size: 1.2rem;
    line-height: 1.7;
    max-width: 65ch;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  /* Stats Section styles */
  .stats-section {
    padding: 3rem 0;
    border-top: 1px solid var(--border-dark);
    border-bottom: 1px solid var(--border-dark);
  }

  .stat-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat-number {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: 3rem;
    color: var(--accent);
    line-height: 1;
    background: linear-gradient(135deg, var(--accent), var(--amber));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stat-unit {
    font-size: 1.5rem;
    font-weight: 500;
  }

  .stat-label {
    font-size: 0.95rem;
    color: var(--text-light-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 500;
  }

  /* Services Grid Section styles */
  .service-overview-card {
    transition: all var(--transition-normal);
  }

  .service-icon-box {
    width: 64px;
    height: 64px;
    background: rgba(249, 115, 22, 0.05);
    border: 1px solid rgba(249, 115, 22, 0.15);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all var(--transition-normal);
  }

  .service-overview-card:hover .service-icon-box {
    background: var(--accent);
    border-color: var(--accent);
  }

  .service-overview-card:hover .service-icon-box svg {
    stroke: var(--text-light);
    fill: none;
  }

  .service-overview-card:hover .service-icon-box svg circle {
    fill: none;
  }

  .service-overview-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .service-overview-card p {
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .learn-more-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
  }

  .learn-more-link:hover {
    color: var(--text-light);
  }

  .learn-more-link svg {
    transition: transform var(--transition-fast);
  }

  .learn-more-link:hover svg {
    transform: translateX(3px);
  }

  /* Competency Section styles */
  .competency-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .competency-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .competency-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
  }

  .check-icon {
    flex-shrink: 0;
  }

  /* Custom CSS Blueprint Track Graphic */
  .competency-visual {
    background: rgba(30, 41, 59, 0.4);
    border: 1px solid var(--border-dark);
    height: 350px;
    border-radius: var(--radius-lg);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .visual-blueprint {
    width: 80%;
    height: 100px;
    border: 1px dashed rgba(249, 115, 22, 0.2);
    position: relative;
  }

  .blueprint-line {
    position: absolute;
    height: 4px;
    background: linear-gradient(90deg, rgba(249, 115, 22, 0.1), var(--accent), rgba(249, 115, 22, 0.1));
    left: 0;
    right: 0;
  }

  .track-horizontal-1 { top: 25px; }
  .track-horizontal-2 { bottom: 25px; }

  .blueprint-sleeper {
    position: absolute;
    width: 6px;
    height: 60px;
    background: var(--text-muted);
    opacity: 0.3;
    top: 20px;
  }

  .s-1 { left: 15%; }
  .s-2 { left: 32%; }
  .s-3 { left: 50%; }
  .s-4 { left: 68%; }
  .s-5 { left: 85%; }

  .blueprint-label {
    position: absolute;
    bottom: -30px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 0.75rem;
    font-family: var(--font-title);
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  /* CTA Banner styles */
  .cta-banner {
    border-top: 1px solid var(--border-dark);
    background: radial-gradient(circle at center, rgba(249, 115, 22, 0.05) 0%, transparent 80%);
  }

  .cta-banner h2 {
    font-size: 2.2rem;
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.1rem;
  }

  @media (max-width: 992px) {
    .competency-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 576px) {
    .hero-ctas {
      flex-direction: column;
    }
  }
</style>
